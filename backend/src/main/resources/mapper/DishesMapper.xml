  <!-- ========== 推荐模块自定义 SQL ========== -->

  <!-- R5 + R17: 全店热门菜品（按 category 分组取 Top-N）-->
  <!-- 使用窗口函数 ROW_NUMBER 按每个分类内销量排序 -->
  <select id="selectHotDishesByCategory" resultType="java.util.Map">
    SELECT d.dish_id AS dishid, d.name AS name, d.category AS category,
           d.price AS price, d.image_url AS imageurl,
           d.tags AS tags, COALESCE(s.cnt, 0) AS ordercount
    FROM public.dishes d
    LEFT JOIN (
        SELECT oi.dish_id, COUNT(*) as cnt
        FROM public.order_items oi
        GROUP BY oi.dish_id
    ) s ON d.dish_id = s.dish_id
    WHERE d.is_active = true
      AND d.dish_id IN (
          SELECT dish_id FROM (
              SELECT oi2.dish_id,
                     ROW_NUMBER() OVER (PARTITION BY d2.category ORDER BY COUNT(*) DESC) as rn
              FROM public.order_items oi2
              INNER JOIN public.dishes d2 ON oi2.dish_id = d2.dish_id
              WHERE d2.is_active = true
              GROUP BY oi2.dish_id, d2.category
          ) ranked WHERE rn &lt;= #{limitPerCategory}
      )
    ORDER BY d.category, ordercount DESC
  </select>

  <!-- R2: 按口味标签匹配 -->
  <select id="selectByTagKeyword" resultType="cn.edu.bjfu.nekocafe.entity.Dishes">
