/* pages/staff/refund.wxss — 退款审核页 */
.refund-page {
  min-height: 100vh;
  background: var(--color-bg, #F7F0EB);
}

.refund-header {
  background: linear-gradient(135deg, #8B5A3C, #5D3A1A);
  padding: 28rpx;
  color: #fff;
}
.refund-title { font-size: 34rpx; font-weight: 700; display: block; }
.refund-sub { font-size: 22rpx; opacity: 0.75; margin-top: 6rpx; display: block; }

.loading-wrap {
  display: flex; flex-direction: column; align-items: center; padding: 120rpx 0;
}
.loading-spinner {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid #E8DDD5; border-top-color: #C97E5A;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 26rpx; color: #999; margin-top: 16rpx; }

.refund-filter {
  display: flex; background: #fff; border-bottom: 1rpx solid #f0f0f0;
}
.rf-item {
  flex: 1; text-align: center; padding: 20rpx 0;
  font-size: 26rpx; color: #999; position: relative;
}
.rf-active { color: #8B5A3C; font-weight: 600; }
.rf-active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%); width: 48rpx; height: 4rpx;
  background: #8B5A3C; border-radius: 2rpx;
}

.refund-list { padding: 16rpx 20rpx; }
.refund-card {
  background: #fff; border-radius: 20rpx; padding: 24rpx;
  margin-bottom: 16rpx; box-shadow: 0 2rpx 16rpx rgba(201,126,90,0.08);
  border-left: 6rpx solid #FF9800;
}
.refund-card-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx;
}
.refund-id { font-size: 28rpx; font-weight: 700; color: #333; }
.refund-status-tag {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 12rpx; font-weight: 600;
}
.rst-REQUEST_CANCEL,
.rst-REQUEST_REFUND { background: #FFF8E1; color: #F57F17; }
.rst-COMPLETED { background: #E8F5E9; color: #388E3C; }
.rst-REJECTED { background: #FAFAFA; color: #9E9E9E; }

.refund-card-body { margin-bottom: 16rpx; }
.refund-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 10rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.refund-row:last-child { border-bottom: none; }
.refund-label { font-size: 24rpx; color: #999; }
.refund-value { font-size: 24rpx; color: #333; }
.refund-amount { font-size: 32rpx; font-weight: 700; color: #E74C3C; }
.refund-type { font-weight: 600; color: #C97E5A; }

.refund-actions { display: flex; gap: 12rpx; padding-top: 12rpx; border-top: 1rpx dashed #eee; }

/* 按钮 */
.btn { padding: 12rpx 28rpx; border-radius: 28rpx; font-size: 26rpx; font-weight: 600; text-align: center; }
.btn-primary { background: #C97E5A; color: #fff; }
.btn-outline { background: #fff; color: #8B5A3C; border: 1rpx solid #8B5A3C; }
.btn-danger { background: #E74C3C; color: #fff; }
.btn-danger-outline { background: #FDEDEC; color: #E74C3C; border: 1rpx solid #E74C3C; }
.btn-block { flex: 1; margin-bottom: 8rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }

/* 弹层 */
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  z-index: 999; display: flex; align-items: flex-end;
}
.modal-panel {
  width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx; padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  box-sizing: border-box; animation: slideUp 0.25s ease-out;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.modal-title { font-size: 32rpx; font-weight: 700; color: #333; display: block; margin-bottom: 20rpx; }
.modal-sub { font-size: 24rpx; color: #999; display: block; margin-bottom: 16rpx; }
.reject-textarea {
  width: 100%; height: 160rpx; background: #F7F0EB; border-radius: 16rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; color: #333;
  margin-bottom: 20rpx; box-sizing: border-box;
}
.modal-btns { display: flex; gap: 16rpx; }
