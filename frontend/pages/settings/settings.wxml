<!--pages/settings/settings.wxml-->
<view class="container">
  <view class="settings-section card">
    <view
      wx:for="{{settings}}"
      wx:key="label"
      class="setting-item"
    >
      <view class="setting-icon">{{item.icon}}</view>
      <text class="setting-label">{{item.label}}</text>
      <view wx:if="{{item.toggle !== undefined}}" class="setting-toggle-wrap">
        <switch 
          class="setting-toggle" 
          checked="{{item.value}}" 
          bindchange="toggleSetting"
          data-index="{{index}}"
        />
      </view>
      <view wx:elif="{{item.path}}" class="setting-arrow-wrap" bindtap="goPage" data-path="{{item.path}}">
        <text class="setting-arrow">›</text>
      </view>
      <text wx:else class="setting-value">{{item.value}}</text>
    </view>
  </view>

  <view class="settings-section card">
    <view class="setting-item" bindtap="clearCache">
      <view class="setting-icon">🗑️</view>
      <text class="setting-label">清除缓存</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="goAbout">
      <view class="setting-icon">ℹ️</view>
      <text class="setting-label">关于我们</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <view class="logout-btn" bindtap="onLogout">退出登录</view>
</view>