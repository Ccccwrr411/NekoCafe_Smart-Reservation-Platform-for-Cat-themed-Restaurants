/* pages/order/order.wxss */

/* ============ 无预约引导 ============ */
.no-reserve-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
}
.nr-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
}
.nr-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 10rpx;
}
.nr-desc {
  font-size: 25rpx;
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
}
.nr-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #D4936E, #C97E5A);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(201,126,90,0.3);
}
.nr-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* ============ 页面头部 ============ */
.page-header {
  padding: 32rpx 32rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.page-header-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--color-secondary);
  letter-spacing: 1rpx;
}
.page-header-sub {
  font-size: 25rpx;
  color: var(--color-text-sub);
}

/* ============ 通用卡片头部 ============ */
.card-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}
.card-icon-wrap {
  width: 52rpx; height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.card-icon {
  font-size: 28rpx;
}
.card-header-text {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}
.card-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}
.card-header-badge {
  font-size: 22rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* ============ 预约信息卡 ============ */
.reserve-card {
  padding: 20rpx 28rpx 24rpx;
}
/* 门店+桌位双栏 */
.reserve-duo {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.reserve-duo-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 20rpx 12rpx;
  background: linear-gradient(135deg, #FFF8F5, #FDF2EB);
  border-radius: 16rpx;
}
.rd-icon {
  font-size: 36rpx;
}
.rd-label {
  font-size: 20rpx;
  color: var(--color-text-sub);
}
.rd-val {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-secondary);
  text-align: center;
  line-height: 1.3;
}
/* 元信息标签组 */
.reserve-meta-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.reserve-meta-tag {
  padding: 8rpx 18rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 23rpx;
  color: var(--color-text);
}
.reserve-hint {
  text-align: center;
  padding: 24rpx 0;
  font-size: 25rpx;
  color: #999;
}
/* 切换按钮 */
.reservation-switch {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-left: auto;
  padding: 4rpx 14rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 20rpx;
}

/* ============ 菜品清单 ============ */
.cart-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f9f4f0;
  gap: 16rpx;
}
.cart-item:last-child {
  border-bottom: none;
}
.cart-item-img {
  width: 88rpx; height: 88rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg);
}
.cart-item-img-placeholder {
  width: 88rpx; height: 88rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.cart-item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cart-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}
.cart-item-bottom {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.cart-item-unit {
  font-size: 24rpx;
  color: var(--color-text-sub);
}
.cart-item-qty {
  font-size: 22rpx;
  color: var(--color-primary);
  background: #FFF5F0;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.cart-item-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-secondary);
}

/* ============ 备注 ============ */
.remark-input {
  width: 100%;
  min-height: 90rpx;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* ============ 优惠券入口 ============ */
.coupon-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
}
.coupon-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.coupon-tag-selected {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 25rpx;
  color: var(--color-primary);
  font-weight: 600;
}
.coupon-save {
  color: #4CAF50;
  font-weight: 700;
}
.coupon-hint {
  font-size: 25rpx;
  color: var(--color-text-sub);
}
.coupon-arrow {
  font-size: 38rpx;
  color: #ccc;
  font-weight: 300;
}

/* ============ 价格明细 ============ */
.price-card {
  padding: 20rpx 28rpx 24rpx;
}
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: var(--color-text);
}
.discount-row {
  color: #388E3C;
}
.discount-val {
  color: #388E3C;
  font-weight: 500;
}
.final-price-row {
  padding-top: 20rpx;
  align-items: flex-end;
}
.final-price-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  padding-bottom: 2rpx;
}
.final-price-block {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.final-price-symbol {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.final-price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}
.price-skipped {
  opacity: 0.4;
}
.price-save {
  color: #388E3C;
}

/* ============ 底部提交栏 ============ */
.submit-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -6rpx 24rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.submit-left {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.submit-label {
  font-size: 23rpx;
  color: var(--color-text-sub);
}
.submit-price-block {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.submit-currency {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.submit-price {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -1rpx;
}
.btn-submit {
  background: linear-gradient(135deg, #D4936E, #C97E5A);
  color: #fff;
  border-radius: 50rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 72rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(201,126,90,0.35);
  transition: all 0.15s;
}
.btn-submit::after { border: none; }
.btn-submit:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ============ 弹层通用 ============ */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 299;
}
.picker-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 300;
  max-height: 66vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-handle {
  width: 60rpx; height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  margin: 16rpx auto 8rpx;
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.picker-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}
.picker-header-close {
  font-size: 36rpx;
  color: var(--color-text-sub);
  padding: 8rpx;
}
.picker-list {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}
.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f9f4f0;
  transition: background 0.15s;
}
.picker-item-on {
  background: #FDF6F2;
}
.picker-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}
.picker-item-store {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
.picker-item-table {
  font-size: 24rpx;
  color: var(--color-primary);
}
.picker-item-time {
  font-size: 22rpx;
  color: var(--color-text-sub);
}
.picker-radio {
  width: 46rpx; height: 46rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  transition: all 0.15s;
}
.radio-on {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* ============ 叠加规则 ============ */
.stacking-rules {
  padding: 16rpx 32rpx;
  background: #FFF8F5;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.stacking-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 8rpx;
}
.stacking-rule-item {
  font-size: 22rpx;
  color: var(--color-text-sub);
  display: block;
  line-height: 1.8;
}

/* ============ 优惠券子元素 ============ */
.empty-coupon {
  padding: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-sub);
}
.coupon-unavailable {
  font-size: 20rpx;
  color: #999;
}
.coupon-not-stackable {
  font-size: 20rpx;
  color: #E65100;
  background: #FFF3E0;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}
.coupon-disabled {
  opacity: 0.45;
}

/* ============ 空状态 ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 48rpx 0;
  color: var(--color-text-sub);
}
.empty-icon {
  font-size: 60rpx;
}

/* ============ 通用覆盖 ============ */
.card {
  padding: 20rpx 28rpx;
  margin: 14rpx 24rpx;
}
