/* pages/order/order.wxss */

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

/* ── 预约信息 ── */
.reserve-card {}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: var(--color-text-sub); }
.info-val   { font-size: 26rpx; color: var(--color-text); }
.no-reserve-hint { font-size: 26rpx; color: var(--color-text-sub); text-align: center; padding: 16rpx 0; }

/* ── 菜品条目 ── */
.order-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  gap: 16rpx;
}
.order-item:last-child { border-bottom: none; }
.order-item-img {
  width: 80rpx; height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.order-item-info { flex: 1; }
.order-item-name  { font-size: 28rpx; color: var(--color-text); display: block; }
.order-item-price { font-size: 24rpx; color: var(--color-text-sub); margin-top: 4rpx; display: block; }
.order-item-subtotal { font-size: 28rpx; color: var(--color-primary); font-weight: 500; }

/* ── 备注 ── */
.remark-input {
  width: 100%;
  min-height: 100rpx;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* ── 优惠券 ── */
.coupon-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.coupon-row .card-title { margin-bottom: 0; }
.coupon-right { display: flex; align-items: center; gap: 8rpx; }
.coupon-selected { font-size: 26rpx; color: var(--color-primary); font-weight: 500; }
.coupon-hint { font-size: 26rpx; color: var(--color-text-sub); }
.coupon-arrow { font-size: 36rpx; color: var(--color-text-sub); }

/* ── 价格明细 ── */
.price-detail {}
.price-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: var(--color-text);
}
.discount-row { color: #388E3C; }
.discount-val { color: #388E3C; font-weight: 500; }
.total-row { padding-top: 16rpx; }
.total-label { font-size: 30rpx; font-weight: 600; }
.total-val   { font-size: 36rpx; font-weight: 700; color: var(--color-primary); }

/* ── 底部提交 ── */
.submit-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
  z-index: 100;
}
.submit-total { display: flex; align-items: baseline; gap: 8rpx; }
.submit-label { font-size: 26rpx; color: var(--color-text-sub); }
.submit-price { font-size: 40rpx; font-weight: 700; color: var(--color-primary); }
.btn-submit {
  background: var(--color-primary);
  color: #fff;
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-submit::after { border: none; }
.price-skipped { opacity: 0.4; }
.price-save { color: #388E3C; }

/* ── 优惠券选择弹层 ── */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 299;
}
.coupon-picker-panel {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 300;
  max-height: 65vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.picker-header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}
.picker-header-close {
  font-size: 36rpx;
  color: var(--color-text-sub);
  padding: 8rpx;
}
.stacking-rules {
  padding: 16rpx 32rpx;
  background: #FFF8F5;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.stacking-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 8rpx;
}
.stacking-rule-item {
  font-size: 22rpx;
  color: var(--color-text-sub);
  display: block;
  line-height: 1.8;
}
.picker-list {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}
.empty-coupon {
  padding: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-sub);
}
.coupon-picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.coupon-checked {
  background: #FDF6F2;
}
.coupon-disabled {
  opacity: 0.45;
}
.coupon-unavailable {
  font-size: 20rpx;
  color: #999;
}
.coupon-picker-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}
.coupon-picker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
.coupon-picker-rule {
  font-size: 24rpx;
  color: var(--color-primary);
}
.coupon-picker-expire {
  font-size: 22rpx;
  color: var(--color-text-sub);
}
.coupon-not-stackable {
  font-size: 20rpx;
  color: #E65100;
  background: #FFF3E0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}
.coupon-checkbox {
  width: 44rpx; height: 44rpx;
  border-radius: 8rpx;
  border: 3rpx solid #ddd;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}
.checkbox-on {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
