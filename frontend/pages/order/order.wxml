<!--pages/order/order.wxml-->
<view class="container">

  <!-- ══ 预约信息 ══ -->
  <view class="card reserve-card">
    <view class="card-title">📅 预约信息</view>
    <view wx:if="{{reserveInfo}}">
      <view class="info-row">
        <text class="info-label">门店</text>
        <text class="info-val">{{reserveInfo.store.name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">桌位</text>
        <text class="info-val">{{reserveInfo.table.name}}（{{reserveInfo.table.type}}）</text>
      </view>
      <view class="info-row">
        <text class="info-label">猫咪</text>
        <text class="info-val">🐾 {{reserveInfo.table.catName}}</text>
      </view>
    </view>
    <view wx:else class="no-reserve-hint">
      <text>未选择桌位（仅点餐）</text>
    </view>
  </view>

  <!-- ══ 菜品清单 ══ -->
  <view class="card">
    <view class="card-title">🍽 已点菜品</view>
    <view wx:if="{{cartItems.length === 0}}" class="empty-state">
      <text>🛒 购物车是空的，请先点单</text>
    </view>
    <view wx:else>
      <view
        wx:for="{{cartItems}}"
        wx:key="id"
        class="order-item"
      >
        <image class="order-item-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="order-item-info">
          <text class="order-item-name">{{item.name}}</text>
          <text class="order-item-price">¥{{item.price}} × {{item.qty}}</text>
        </view>
        <text class="order-item-subtotal">¥{{item.price * item.qty}}</text>
      </view>
    </view>
  </view>

  <!-- ══ 备注 ══ -->
  <view class="card">
    <view class="card-title">📝 备注</view>
    <textarea
      class="remark-input"
      placeholder="有什么特殊需求？比如不要香菜、宝宝椅..."
      maxlength="100"
      bindinput="onRemarkInput"
    />
  </view>

  <!-- ══ 优惠券 ══ -->
  <view class="card coupon-row" bindtap="onOpenCouponPicker">
    <view class="card-title">🎫 优惠券与活动</view>
    <view class="coupon-right">
      <text wx:if="{{selectedCouponIds.length > 0}}" class="coupon-selected">已选{{selectedCouponIds.length}}张 -¥{{totalDiscount}}</text>
      <text wx:else class="coupon-hint">点击选择优惠</text>
      <text class="coupon-arrow">›</text>
    </view>
  </view>

  <!-- ══ 优惠券选择弹层 ══ -->
  <view wx:if="{{showCouponPicker}}" class="picker-mask" bindtap="onCloseCouponPicker"></view>
  <view wx:if="{{showCouponPicker}}" class="coupon-picker-panel" catchtap="onPickerPanelTap">
    <view class="picker-header">
      <text class="picker-header-title">选择优惠</text>
      <text class="picker-header-close" bindtap="onCloseCouponPicker">✕</text>
    </view>

    <!-- 叠加规则 -->
    <view wx:if="{{stackingRules}}" class="stacking-rules">
      <text class="stacking-title">📋 叠加规则：最多叠加{{stackingRules.maxStackCount}}张</text>
      <text wx:for="{{stackingRules.rules}}" wx:for-item="rule" wx:key="idx" class="stacking-rule-item">· {{rule.text}}</text>
    </view>

    <!-- 可用优惠券 -->
    <view class="picker-list">
      <view wx:if="{{coupons.length === 0}}" class="empty-coupon">
        <text>暂无可用优惠券</text>
      </view>
      <view
        wx:for="{{coupons}}"
        wx:for-item="coupon"
        wx:key="id"
        class="coupon-picker-item {{coupon.itemClass}}"
        catchtap="onToggleCoupon"
        data-coupon-id="{{coupon.id}}"
      >
        <view class="coupon-picker-left">
          <text class="coupon-picker-name">{{coupon.name}}</text>
          <text class="coupon-picker-rule">{{coupon.ruleText}}</text>
          <text class="coupon-picker-expire">有效期至 {{coupon.expireDate}}</text>
          <text wx:if="{{coupon.unavailableHint}}" class="coupon-unavailable">{{coupon.unavailableHint}}</text>
          <text wx:elif="{{!coupon.stackable}}" class="coupon-not-stackable">⚠ 不可叠加</text>
        </view>
        <view class="coupon-checkbox {{coupon.checkboxClass}}">
          {{coupon.checkboxText}}
        </view>
      </view>
    </view>
  </view>

  <!-- ══ 价格明细 ══ -->
  <view class="card price-detail">
    <view wx:for="{{discountBreakdown}}" wx:for-item="row" wx:key="label" class="price-row {{row.rowClass}}">
      <text class="{{row.labelClass}}">{{row.label}}</text>
      <text class="{{row.amountClass}}">{{row.amountText}}</text>
    </view>
    <view class="divider"></view>
    <view class="price-row total-row">
      <text class="total-label">实付金额</text>
      <text class="total-val">¥{{finalTotal}}</text>
    </view>
  </view>

  <!-- ══ 底部提交 ══ -->
  <view class="submit-bar">
    <view class="submit-total">
      <text class="submit-label">合计</text>
      <text class="submit-price">¥{{finalTotal}}</text>
    </view>
    <button
      class="btn-submit {{submitting ? 'btn-disabled' : ''}}"
      bindtap="onSubmit"
      loading="{{submitting}}"
    >{{submitting ? '提交中...' : '立即下单'}}</button>
  </view>

</view>
