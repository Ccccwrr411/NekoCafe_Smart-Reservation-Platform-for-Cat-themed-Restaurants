/* pages/profile/profile.wxss */

/* ── 用户顶部卡片 ── */
.user-hero {
  background: linear-gradient(135deg, #C97E5A, #8B5A3C);
  padding: 40rpx 28rpx 0;
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 20rpx;
}
.user-info-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.user-detail { flex: 1; }
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.user-member-badge {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin: 8rpx 0;
  display: inline-block;
}
.user-phone {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

/* ── 积分进度 ── */
.points-section {
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.points-val  { font-size: 28rpx; font-weight: 600; color: #fff; }
.points-hint { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.progress-bar {
  height: 10rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: #FFD54F;
  border-radius: 5rpx;
  transition: width 0.5s;
}

/* ── 数据概览 ── */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx 16rpx 0 0;
  padding: 20rpx 0;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.stat-num   { font-size: 36rpx; font-weight: 700; color: #fff; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.3);
}

/* ── 区块标题 ── */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 8rpx;
}
.section-title-text { font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.section-more       { font-size: 24rpx; color: var(--color-text-sub); }

/* ── 订单卡片 ── */
.order-card { padding: 20rpx 24rpx; }
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.order-store  { font-size: 28rpx; font-weight: 500; color: var(--color-text); }
.order-status { font-size: 24rpx; font-weight: 500; }
.order-meta   { font-size: 24rpx; color: var(--color-text-sub); display: block; margin-bottom: 8rpx; }
.order-items-preview {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}
.order-dish-name {
  font-size: 22rpx;
  color: var(--color-text-sub);
  background: var(--color-bg);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border);
}
.order-total { font-size: 28rpx; font-weight: 600; color: var(--color-primary); }
.order-actions { display: flex; gap: 12rpx; }
.btn-review {
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}
.btn-cancel {
  border: 2rpx solid var(--color-text-sub);
  color: var(--color-text-sub);
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

/* ── 功能菜单 ── */
.menu-section { padding: 0; overflow: hidden; }
.menu-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  gap: 20rpx;
}
.menu-row:last-child { border-bottom: none; }
.menu-icon  { font-size: 36rpx; width: 48rpx; text-align: center; }
.menu-label { flex: 1; font-size: 28rpx; color: var(--color-text); }
.menu-arrow { font-size: 36rpx; color: var(--color-text-sub); }

/* ── 版本号 ── */
.app-version {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-sub);
  padding: 30rpx 0 24rpx;
}

/* ── 退出登录 ── */
.logout-btn {
  margin: 0 40rpx 60rpx;
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #ffccc7;
  color: #E74C3C;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}
