<!--pages/realname/realname.wxml-->
<view class="container">

  <!-- 已认证状态 -->
  <view wx:if="{{verified}}" class="verified-card">
    <text class="verified-icon">✅</text>
    <text class="verified-title">您已完成实名认证</text>
    <view class="verified-info">
      <text>姓名：{{verifiedInfo.realName}}</text>
      <text>身份证号：{{verifiedInfo.idCardMask}}</text>
    </view>
  </view>

  <!-- 未认证表单 -->
  <block wx:else>
    <view class="tip-card">
      <text class="tip-icon">🛡️</text>
      <text class="tip-text">实名认证后可用于会员权益兑换、发票开具及安全支付保障。</text>
    </view>

    <view class="form-card">
      <view class="form-row">
        <text class="form-label">真实姓名</text>
        <input class="form-input" placeholder="请输入您的真实姓名" value="{{realName}}" bindinput="onRealNameInput" />
      </view>
      <view class="form-row">
        <text class="form-label">身份证号</text>
        <input class="form-input" placeholder="请输入18位身份证号" value="{{idCard}}" maxlength="18" bindinput="onIdCardInput" />
      </view>
    </view>

    <view class="btn-primary {{submitting?'disabled':''}}" bindtap="onSubmit">
      {{submitting?'提交中...':'提交认证'}}
    </view>
  </block>

</view>
