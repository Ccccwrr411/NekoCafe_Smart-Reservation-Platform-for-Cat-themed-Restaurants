/* pages/realname/realname.wxss */
@import "../../app.wxss";

.verified-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.verified-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.verified-title { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 24rpx; }
.verified-info text { display: block; font-size: 28rpx; color: #666; margin-top: 8rpx; }

.tip-card {
  background: #FFF8F0;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}
.tip-icon { font-size: 40rpx; margin-right: 16rpx; }
.tip-text { font-size: 26rpx; color: #8B6B4E; line-height: 1.6; flex: 1; }

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-row:last-child { border-bottom: none; }
.form-label { width: 160rpx; font-size: 28rpx; color: #333; font-weight: 500; }
.form-input { flex: 1; font-size: 28rpx; color: #333; }

.btn-primary.disabled { opacity: 0.6; }
