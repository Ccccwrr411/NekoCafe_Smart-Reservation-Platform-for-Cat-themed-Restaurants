/* pages/editProfile/editProfile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.card {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.form-section {
  padding: 8rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 120rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.avatar-item {
  flex-direction: column;
  align-items: flex-start;
  padding: 32rpx 24rpx;
}

.avatar-wrap {
  position: relative;
  margin-top: 16rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #C97E5A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon {
  font-size: 24rpx;
}

.gender-options {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.gender-option {
  padding: 12rpx 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.gender-option.active {
  border-color: #C97E5A;
  color: #C97E5A;
  background: rgba(201, 126, 90, 0.1);
}

.date-picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-picker text:first-child {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.submit-btn {
  margin: 40rpx 24rpx;
  background: linear-gradient(135deg, #C97E5A, #8B5A3C);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}