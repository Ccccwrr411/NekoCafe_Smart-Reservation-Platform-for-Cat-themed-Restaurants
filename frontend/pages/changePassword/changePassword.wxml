<!--pages/changePassword/changePassword.wxml-->
<view class="container">
  <view wx:if="{{hasPassword}}" class="form-item">
    <text class="label">旧密码</text>
    <input 
      class="input" 
      type="password" 
      placeholder="请输入旧密码" 
      value="{{oldPassword}}"
      bindinput="onOldPasswordInput"
    />
  </view>

  <view wx:else class="tips">
    <text>您尚未设置密码，请直接设置新密码</text>
  </view>

  <view class="form-item">
    <text class="label">新密码</text>
    <input 
      class="input" 
      type="password" 
      placeholder="请输入新密码（至少6位）" 
      value="{{newPassword}}"
      bindinput="onNewPasswordInput"
    />
  </view>

  <view class="form-item">
    <text class="label">确认密码</text>
    <input 
      class="input" 
      type="password" 
      placeholder="请再次输入新密码" 
      value="{{confirmPassword}}"
      bindinput="onConfirmPasswordInput"
    />
  </view>

  <button class="submit-btn" bindtap="submit">确认{{hasPassword ? '修改' : '设置'}}</button>
</view>