/* pages/changePassword/changePassword.wxss */
.container {
  padding: 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 10rpx;
}

.tips {
  background: #FFF3E0;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #E65100;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: white;
  font-size: 32rpx;
  border-radius: 45rpx;
  margin-top: 40rpx;
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
}