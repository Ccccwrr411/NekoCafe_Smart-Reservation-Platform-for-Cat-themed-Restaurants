<!--pages/queue/queue.wxml-->
<view class="container">

  <view wx:if="{{loading}}" class="loading-wrap"><text>加载中...</text></view>

  <block wx:if="{{!loading && queue}}">

    <!-- 当前叫号 -->
    <view class="now-serving">
      <text class="now-label">当前叫号</text>
      <text class="now-number">{{queue.currentNumber}}</text>
      <text class="now-hint">共 {{queue.waitingCount}} 桌等待 · 预计等待 {{queue.avgWaitMinutes}} 分钟</text>
    </view>

    <!-- 我的号码 -->
    <view class="my-number-card" wx:if="{{queue.myNumber}}">
      <view class="my-number-left">
        <text class="my-label">我的号码</text>
        <text class="my-num">{{queue.myNumber}}</text>
      </view>
      <view class="my-number-right">
        <text class="my-wait">前面还有 {{queue.myWaitMinutes}} 分钟</text>
        <text class="my-hint">请留意叫号，过号需重新排队</text>
      </view>
    </view>

    <!-- 取号按钮 -->
    <view wx:if="{{!queue.myNumber}}" class="btn-primary" bindtap="onTakeNumber">
      {{taking?'取号中...':'立即取号'}}
    </view>

    <!-- 排队列表 -->
    <view class="section-title">排队列表</view>
    <view class="queue-list">
      <view wx:for="{{queue.queueList}}" wx:key="number" class="queue-item">
        <view class="queue-num">{{item.number}}号</view>
        <view class="queue-info">
          <text>{{item.persons}}人 · {{item.type}}</text>
          <text class="queue-ahead">前面 {{item.ahead}} 桌</text>
        </view>
      </view>
    </view>

  </block>

</view>
