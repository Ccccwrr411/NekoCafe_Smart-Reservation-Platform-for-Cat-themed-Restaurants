/* pages/cats/cats.wxss */

/* ── 列表模式 ── */
.cats-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}
.cat-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.cat-img {
  width: 100%;
  height: 240rpx;
}
.cat-info {
  padding: 16rpx;
}
.cat-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}
.cat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.cat-gender {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}
.gender-female { background: #FCE4EC; color: #E91E63; }
.gender-male { background: #E3F2FD; color: #2196F3; }
.cat-breed {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 6rpx;
}
.cat-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 10rpx;
}
.cat-meta-item {
  font-size: 22rpx;
  color: #666;
}
.cat-personality {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 8rpx;
}
.personality-tag {
  font-size: 20rpx;
  color: #C97E5A;
  background: #FFF3E0;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}
.cat-tap-hint {
  font-size: 22rpx;
  color: var(--color-primary);
  display: block;
  text-align: right;
}

/* ── 详情模式 ── */
.detail-wrap {
  padding-bottom: 60rpx;
}
.detail-back {
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-primary);
  background: #fff;
  border-bottom: 1rpx solid var(--color-border);
}
.detail-hero {
  display: flex;
  background: #fff;
  padding: 24rpx;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.detail-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
.detail-hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.detail-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}
.detail-breed-age {
  font-size: 26rpx;
  color: var(--color-text-sub);
}
.detail-desc {
  font-size: 24rpx;
  color: var(--color-text-sub);
  line-height: 1.6;
}
.detail-personality {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

/* 通用卡片 */
.detail-card {
  background: #fff;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.detail-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

/* 健康评分 */
.health-score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.health-score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #81C784);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.score-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
.score-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}
.health-advice {
  font-size: 24rpx;
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.6;
}

/* 体重趋势 */
.weight-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-sub);
}
.weight-range {
  color: #999;
}
.weight-chart-canvas {
  width: 100%;
  height: 340rpx;
}

/* 疫苗记录 */
.vaccine-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.vaccine-item:last-child { border-bottom: none; }
.vaccine-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.vaccine-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
.vaccine-date {
  font-size: 22rpx;
  color: var(--color-text-sub);
}
.vaccine-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.status-valid { background: #E8F5E9; color: #2E7D32; }
.status-expiring { background: #FFF3E0; color: #E65100; }
.status-expired { background: #FFEBEE; color: #C62828; }

/* 互动时间线 */
.timeline {
  position: relative;
  padding-left: 24rpx;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 6rpx;
  bottom: 6rpx;
  width: 3rpx;
  background: #eee;
}
.timeline-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
}
.timeline-item:last-child { margin-bottom: 0; }
.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
  left: -15rpx;
  top: 6rpx;
  z-index: 1;
}
.mood-happy { background: #4CAF50; }
.mood-grumpy { background: #FF9800; }
.mood-neutral { background: #2196F3; }
.timeline-content {
  flex: 1;
}
.timeline-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.timeline-date {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}
.timeline-type {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
.timeline-desc {
  font-size: 24rpx;
  color: var(--color-text-sub);
  line-height: 1.5;
}
