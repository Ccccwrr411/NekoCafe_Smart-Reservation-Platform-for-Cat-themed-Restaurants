/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #C97E5A 0%, #F7F0EB 60%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  box-sizing: border-box;
}

/* ── Logo ── */
.login-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}
.logo-cat  { font-size: 100rpx; margin-bottom: 12rpx; }
.logo-name { font-size: 52rpx; font-weight: 800; color: #fff; letter-spacing: 4rpx; }
.logo-sub  { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 10rpx; }

/* ── 角色选择 ── */
.role-section {
  width: 100%;
  background: rgba(255,255,255,0.95);
  border-radius: 28rpx;
  padding: 36rpx 28rpx 28rpx;
  box-sizing: border-box;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(201,126,90,0.18);
}
.role-title {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
}
.role-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}
.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx 20rpx;
  background: #F7F0EB;
  border-radius: 18rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.role-card-active {
  background: #FFF5F0;
  border-color: #C97E5A;
  box-shadow: 0 0 0 4rpx rgba(201,126,90,0.15);
}
.role-icon  { font-size: 52rpx; margin-bottom: 10rpx; }
.role-name  { font-size: 26rpx; font-weight: 600; color: #333; }
.role-name-en { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.role-card-active .role-name { color: #C97E5A; }

/* ── 登录按钮 ── */
.btn-wx-login {
  width: 100%;
  background: #C97E5A;
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(201,126,90,0.4);
}
.btn-wx-login::after { border: none; }
.btn-disabled {
  background: #ccc !important;
  box-shadow: none !important;
}
.login-hint { font-size: 22rpx; color: rgba(0,0,0,0.4); text-align: center; }
