<!--pages/orderList/orderList.wxml-->
<view class="container">

  <view wx:if="{{loading}}" class="loading-wrap"><text>加载中...</text></view>

  <view wx:else>
    <view wx:if="{{orders.length === 0}}" class="empty-state">
      <text>暂无订单记录</text>
    </view>

    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card card"
      bindtap="onOrderClick"
      data-orderid="{{item.id}}"
    >
      <view class="order-header">
        <text class="order-id">#{{item.id}}</text>
        <text class="order-status" style="color: {{ORDER_STATUS_MAP[item.status].color}}">
          {{ORDER_STATUS_MAP[item.status].text}}
        </text>
      </view>
      <view class="order-body">
        <view class="order-row">
          <text class="order-store">{{item.storeName}}</text>
          <text class="order-table">{{item.tableName}}</text>
        </view>
        <view class="order-row">
          <text class="order-time">{{item.reserveDate}} {{item.reserveTime}} · {{item.duration}}小时</text>
          <text class="order-persons">{{item.persons}}人</text>
        </view>
      </view>
      <view class="order-items" wx:if="{{item.items.length > 0}}">
        <text
          wx:for="{{item.items}}"
          wx:for-item="dish"
          wx:key="name"
          class="dish-name"
        >{{dish.name}}x{{dish.qty}}</text>
      </view>
      <view class="order-footer">
        <text class="order-total" wx:if="{{item.totalAmount > 0}}">¥{{item.totalAmount}}</text>
        <text class="order-arrow">查看详情 ›</text>
      </view>
    </view>
  </view>

</view>
