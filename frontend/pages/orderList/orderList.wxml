<!--pages/orderList/orderList.wxml-->
<view class="container">

  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-left">
      <text class="nav-title">全部订单</text>
    </view>
    <view class="nav-right">
      <text class="search-btn" bindtap="onToggleSearch">{{showSearch ? '✕' : '🔍'}}</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar" wx:if="{{showSearch}}">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索门店、桌位或订单号"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
        focus="{{true}}"
      />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 状态筛选标签 -->
  <scroll-view class="tabs-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
    <view class="tabs-wrap">
      <view
        wx:for="{{filterTabs}}"
        wx:key="key"
        class="tab-item {{activeFilter === item.key ? 'tab-active' : ''}}"
        bindtap="onFilterTap"
        data-key="{{item.key}}"
      >
        <text class="tab-text">{{item.label}}</text>
        <view wx:if="{{activeFilter === item.key}}" class="tab-dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-area">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 订单列表 -->
  <view wx:else class="list-body">
    <!-- 空态 -->
    <view wx:if="{{orders.length === 0}}" class="empty-area">
      <view class="empty-illust">
        <text class="empty-cat">🐱</text>
      </view>
      <text class="empty-title">暂无订单</text>
      <text class="empty-sub">{{activeFilter === 'all' ? '快去猫咖预约吧~' : '该状态下没有找到相关订单'}}</text>
    </view>

    <!-- 订单卡片 -->
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
      bindtap="onOrderClick"
      data-orderid="{{item.id}}"
    >
      <!-- 卡片顶部：门店 + 状态 -->
      <view class="card-top">
        <view class="card-store">
          <view class="store-avatar">🐱</view>
          <view class="store-info">
            <text class="store-name">{{item.storeName}}</text>
            <text class="store-table">{{item.tableName}} · {{item.persons}}人</text>
          </view>
        </view>
        <view class="status-badge" style="background:{{ORDER_STATUS_MAP[item.status].bg}}; color:{{ORDER_STATUS_MAP[item.status].color}}">
          {{ORDER_STATUS_MAP[item.status].text}}
        </view>
      </view>

      <!-- 时间线预览 -->
      <view class="card-timeline" wx:if="{{item.timeline && item.timeline.length > 0}}">
        <view class="tl-dot"></view>
        <view class="tl-line"></view>
        <view class="tl-item">
          <text class="tl-time">{{item.timeline[0].time}}</text>
          <text class="tl-title">{{item.timeline[0].title}}</text>
        </view>
      </view>

      <!-- 菜品标签 -->
      <view class="card-dishes" wx:if="{{item.items && item.items.length > 0}}">
        <text
          wx:for="{{item.items}}"
          wx:for-item="dish"
          wx:key="name"
          class="dish-chip"
        >{{dish.name}}×{{dish.qty}}</text>
        <text wx:if="{{item.items.length > 3}}" class="dish-more">+{{item.items.length - 3}}</text>
      </view>

      <!-- 卡片底部：金额 + 时间 + 操作 -->
      <view class="card-bottom">
        <view class="bottom-left">
          <text class="order-date">{{item.reserveDate}} {{item.reserveTime}}</text>
          <text class="order-duration" wx:if="{{item.duration}}">{{item.duration}}小时</text>
        </view>
        <view class="bottom-right">
          <text class="amount-label" wx:if="{{item.totalAmount > 0}}">合计</text>
          <text class="amount-value" wx:if="{{item.totalAmount > 0}}">¥{{item.totalAmount}}</text>
          <text class="card-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

</view>
