/* pages/orderDetail/orderDetail.wxss */
@import "../../app.wxss";

.status-card {
  background: linear-gradient(135deg, #C97E5A, #A65D3A);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #fff;
  text-align: center;
}
.status-icon { font-size: 64rpx; display: block; margin-bottom: 12rpx; }
.status-text { font-size: 36rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.status-desc { font-size: 26rpx; opacity: 0.9; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #C97E5A;
  padding-left: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}
.info-row:last-child { border-bottom: none; }
.info-label { color: #888; }
.info-val { color: #333; font-weight: 500; }

.item-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #555;
}
.item-price { color: #333; font-weight: 500; }
.total-row, .discount-row, .final-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 8rpx;
}
.total-price { font-weight: 600; }
.discount-price { color: #4CAF50; }
.final-row { font-size: 32rpx; font-weight: 700; }
.final-price { color: #C97E5A; }

.timeline { padding-left: 20rpx; }
.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  position: relative;
}
.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #C97E5A;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}
.timeline-body { flex: 1; }
.timeline-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.timeline-desc { font-size: 24rpx; color: #666; display: block; margin-top: 4rpx; }
.timeline-time { font-size: 22rpx; color: #aaa; display: block; margin-top: 4rpx; }

.action-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 0 40rpx;
}
.btn-outline {
  flex: 1;
  min-width: 200rpx;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #555;
  background: #fff;
}
.btn-danger { border-color: #F44336; color: #F44336; }
.btn-primary {
  flex: 1;
  min-width: 200rpx;
  text-align: center;
  padding: 20rpx 0;
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
