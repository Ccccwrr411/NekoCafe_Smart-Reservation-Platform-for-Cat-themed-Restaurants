<!--pages/orderDetail/orderDetail.wxml-->
<view class="container">

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && order}}">

    <!-- ══ 顶部状态横幅 ══ -->
    <view class="status-hero" style="background: {{ORDER_STATUS_MAP[order.status].bg || '#F5F5F5'}};">
      <!-- 状态图标 + 卡片 -->
      <view class="status-hero-card">
        <view class="hero-icon-wrap" style="background: {{ORDER_STATUS_MAP[order.status].color || '#333'}};">
          <text class="hero-icon">{{order.statusIcon}}</text>
        </view>
        <view class="hero-text">
          <text class="hero-title" style="color: {{ORDER_STATUS_MAP[order.status].color || '#333'}};">{{ORDER_STATUS_MAP[order.status].text || order.statusDesc}}</text>
          <text class="hero-desc">{{order.statusDesc}}</text>
        </view>
      </view>
      <!-- 状态装饰条 -->
      <view class="hero-deco">
        <view class="hero-dot" wx:for="{{[1,2,3,4,5]}}" wx:key="*this" style="background:{{ORDER_STATUS_MAP[order.status].color || '#333'}};opacity:{{0.15 + 0.12 * index}};"></view>
      </view>
    </view>

    <!-- ══ 预约信息卡 ══ -->
    <view class="section-title">
      <text class="st-icon">📋</text>
      <text>预约信息</text>
    </view>
    <view class="card info-card">
      <!-- 门店 + 桌位 做 highlight -->
      <view class="info-highlight">
        <view class="info-highlight-item">
          <text class="hl-label">门店</text>
          <text class="hl-val">{{order.storeName}}</text>
        </view>
        <view class="info-highlight-divider"></view>
        <view class="info-highlight-item">
          <text class="hl-label">桌位</text>
          <text class="hl-val">{{order.tableName}}</text>
        </view>
      </view>
      <view class="info-grid">
        <view class="info-cell">
          <text class="ic-label">顾客</text>
          <text class="ic-val">{{order.customerName || '---'}}</text>
        </view>
        <view class="info-cell">
          <text class="ic-label">日期</text>
          <text class="ic-val">{{order.reserveDate}}</text>
        </view>
        <view class="info-cell">
          <text class="ic-label">时间</text>
          <text class="ic-val">{{order.reserveTime}}（{{order.duration}}h）</text>
        </view>
        <view class="info-cell">
          <text class="ic-label">人数</text>
          <text class="ic-val">{{order.persons}}人</text>
        </view>
      </view>
      <view wx:if="{{order.remark}}" class="remark-tag">
        <text class="remark-icon">💬</text>
        <text>{{order.remark}}</text>
      </view>
    </view>

    <!-- ══ 消费明细（有点单数据） ══ -->
    <block wx:if="{{order.items && order.items.length > 0}}">
      <view class="section-title">
        <text class="st-icon">🍽️</text>
        <text>消费明细</text>
      </view>
      <view class="card">
        <view wx:for="{{order.items}}" wx:key="dishId" class="item-row">
          <view class="item-avatar">
            <text wx:if="{{item.imageUrl}}" class="item-avatar-img" style="background-image:url({{item.imageUrl}})"></text>
            <text wx:else class="item-avatar-placeholder">🐱</text>
          </view>
          <view class="item-body">
            <text class="item-name">{{item.name}}</text>
            <text class="item-qty">×{{item.qty}}</text>
          </view>
          <text class="item-price">¥{{item.price * item.qty}}</text>
        </view>
        <view class="divider"></view>
        <view class="total-row">
          <text>合计</text>
          <text class="total-price">¥{{order.totalAmount}}</text>
        </view>
        <view class="discount-row" wx:if="{{order.discountAmount > 0}}">
          <text class="discount-label">优惠减免</text>
          <text class="discount-price">-¥{{order.discountAmount}}</text>
        </view>
        <view class="final-row">
          <text>实付</text>
          <view class="final-price-wrap">
            <text class="final-currency">¥</text>
            <text class="final-price">{{order.finalAmount}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- ══ 支付信息（已支付） ══ -->
    <block wx:if="{{order.payTime}}">
      <view class="section-title">
        <text class="st-icon">💳</text>
        <text>支付信息</text>
      </view>
      <view class="card">
        <view class="info-row pay-row">
          <view class="pay-method-tag">
            <text class="pay-icon">💳</text>
            <text>{{order.payType || '微信支付'}}</text>
          </view>
          <view class="pay-amount-tag">¥{{order.finalAmount}}</view>
        </view>
        <view class="info-row">
          <text class="info-label">交易时间</text>
          <text class="info-val">{{order.payTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">交易状态</text>
          <text class="info-val" style="color:{{order.status==='cancel_order' || order.status==='cancel_booking' ? '#FF9800' : '#4CAF50'}};">{{order.status==='cancel_order' || order.status==='cancel_booking' ? '✗ 已退款' : '✓ 已支付'}}</text>
        </view>
      </view>
    </block>

    <!-- ══ 售后信息 ══ -->
    <block wx:if="{{order.status==='after_sales_pending' || order.status==='after_sales_rejected' || order.status==='after_sales_completed'}}">
      <view class="section-title">
        <text class="st-icon">🔧</text>
        <text>售后信息</text>
      </view>
      <view class="card">
        <view class="info-row" wx:if="{{order.refundReason}}"><text class="info-label">退款原因</text><text class="info-val">{{order.refundReason}}</text></view>
        <view class="info-row" wx:if="{{order.refundStatus}}"><text class="info-label">退款状态</text><text class="info-val">{{order.refundStatus}}</text></view>
        <view class="info-row" wx:if="{{order.refundCreatedAt}}"><text class="info-label">申请时间</text><text class="info-val">{{order.refundCreatedAt}}</text></view>
        <view class="info-row" wx:if="{{order.refundCompletedAt}}"><text class="info-label">完成时间</text><text class="info-val">{{order.refundCompletedAt}}</text></view>
      </view>
    </block>

    <!-- ══ 订单跟踪（时间线） ══ -->
    <view class="section-title">
      <text class="st-icon">📌</text>
      <text>订单跟踪</text>
    </view>
    <view class="card timeline-card">
      <view class="timeline">
        <view wx:for="{{order.timeline}}" wx:key="time" class="timeline-item {{index === order.timeline.length - 1 ? 'tl-last' : ''}}">
          <view class="timeline-left">
            <view class="timeline-dot {{index === order.timeline.length - 1 ? 'tl-dot-active' : ''}}"></view>
            <view wx:if="{{index < order.timeline.length - 1}}" class="timeline-line"></view>
          </view>
          <view class="timeline-body">
            <view class="timeline-header">
              <text class="timeline-title">{{item.title}}</text>
              <text class="timeline-time">{{item.time}}</text>
            </view>
            <text class="timeline-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ══ 操作按钮 ══ -->
    <view class="action-bar">
      <!-- BOOKED → 去点单 -->
      <view wx:if="{{order.status==='booked'}}" class="action-btn action-primary" bindtap="goOrder">
        <text class="ab-icon">🍽️</text>
        <text>去点单</text>
      </view>
      <!-- CANCEL_ORDER → 重新点单 -->
      <view wx:if="{{order.status==='cancel_order'}}" class="action-btn action-primary" bindtap="goReorder">
        <text class="ab-icon">🔄</text>
        <text>重新点单</text>
      </view>
      <!-- 取消预约 / 取消订单 -->
      <view wx:if="{{order.canCancel && order.status==='booked'}}" class="action-btn action-outline" bindtap="onCancel">
        <text class="ab-icon">✕</text>
        <text>取消预约</text>
      </view>
      <view wx:if="{{order.canCancel && order.status==='confirmed'}}" class="action-btn action-danger" bindtap="onCancel">
        <text class="ab-icon">✕</text>
        <text>取消订单</text>
      </view>
      <view wx:if="{{order.canRefund}}" class="action-btn action-danger" bindtap="onRefund">
        <text class="ab-icon">↩</text>
        <text>申请退款</text>
      </view>
      <view wx:if="{{order.status==='completed' && !order.hasReview}}" class="action-btn action-primary" bindtap="goReview">
        <text class="ab-icon">⭐</text>
        <text>去评价</text>
      </view>
    </view>

  </block>

  <view wx:if="{{!loading && !order}}" class="empty-state">
    <text class="empty-emoji">🐾</text>
    <text>订单不存在或已删除</text>
  </view>

</view>
