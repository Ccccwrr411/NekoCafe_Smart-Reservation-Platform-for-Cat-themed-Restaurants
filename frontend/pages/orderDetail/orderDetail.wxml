<!--pages/orderDetail/orderDetail.wxml-->
<view class="container">

  <view wx:if="{{loading}}" class="loading-wrap"><text>加载中...</text></view>

  <block wx:if="{{!loading && order}}">

    <!-- 状态卡片 -->
    <view class="status-card">
      <text class="status-icon">{{order.status==='completed'?'✅':order.status==='cancelled'?'❌':order.status==='occupied'?'🐱':'📋'}}</text>
      <text class="status-text" style="color: {{ORDER_STATUS_MAP[order.status].color}}">
        {{ORDER_STATUS_MAP[order.status].text}}
      </text>
      <text class="status-desc">{{order.status==='confirmed'?'门店已确认，请准时到店':order.status==='occupied'?'顾客已到店，正在享受猫咪时光':order.status==='completed'?'期待您的评价':order.status==='cancelled'?'已取消，款项已退回':'订单处理中'}}</text>
    </view>

    <!-- 预约信息 -->
    <view class="card">
      <view class="section-title">预约信息</view>
      <view class="info-row"><text class="info-label">门店</text><text class="info-val">{{order.storeName}}</text></view>
      <view class="info-row"><text class="info-label">桌位</text><text class="info-val">{{order.tableName}}</text></view>
      <view class="info-row"><text class="info-label">顾客</text><text class="info-val">{{order.customerName || '---'}}  {{order.customerPhone || ''}}</text></view>
      <view class="info-row"><text class="info-label">日期</text><text class="info-val">{{order.reserveDate}}</text></view>
      <view class="info-row"><text class="info-label">时间</text><text class="info-val">{{order.reserveTime}}（{{order.duration}}小时）</text></view>
      <view class="info-row"><text class="info-label">人数</text><text class="info-val">{{order.persons}}人</text></view>
      <view class="info-row"><text class="info-label">备注</text><text class="info-val">{{order.remark || '无'}}</text></view>
    </view>

    <!-- 消费明细 -->
    <view class="card" wx:if="{{order.items.length > 0}}">
      <view class="section-title">消费明细</view>
      <view wx:for="{{order.items}}" wx:key="name" class="item-row">
        <text class="item-name">{{item.name}} x{{item.qty}}</text>
        <text class="item-price">¥{{item.price * item.qty}}</text>
      </view>
      <view class="total-row">
        <text>合计</text>
        <text class="total-price">¥{{order.totalAmount}}</text>
      </view>
      <view class="discount-row" wx:if="{{order.discountAmount > 0}}">
        <text>优惠</text>
        <text class="discount-price">-¥{{order.discountAmount}}</text>
      </view>
      <view class="final-row">
        <text>实付</text>
        <text class="final-price">¥{{order.finalAmount}}</text>
      </view>
    </view>

    <!-- 支付信息 -->
    <view class="card" wx:if="{{order.payTime}}">
      <view class="section-title">支付信息</view>
      <view class="info-row"><text class="info-label">支付方式</text><text class="info-val">{{order.payType}}</text></view>
      <view class="info-row"><text class="info-label">支付时间</text><text class="info-val">{{order.payTime}}</text></view>
    </view>

    <!-- 订单时间线 -->
    <view class="card">
      <view class="section-title">订单跟踪</view>
      <view class="timeline">
        <view wx:for="{{order.timeline}}" wx:key="time" class="timeline-item">
          <view class="timeline-dot"></view>
          <view class="timeline-body">
            <text class="timeline-title">{{item.title}}</text>
            <text class="timeline-desc">{{item.desc}}</text>
            <text class="timeline-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view wx:if="{{order.canCancel}}" class="btn-outline" bindtap="onCancel">取消预约</view>
      <view wx:if="{{order.canReschedule}}" class="btn-outline" bindtap="onReschedule">修改时间</view>
      <view wx:if="{{order.canRefund}}" class="btn-outline btn-danger" bindtap="onRefund">申请退款</view>
      <view wx:if="{{order.status==='completed' && !order.hasReview}}" class="btn-primary" bindtap="goReview">去评价</view>
    </view>

  </block>

  <view wx:if="{{!loading && !order}}" class="empty-state">
    <text>订单不存在或已删除</text>
  </view>

</view>
